rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return true;
    }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'stock', 'images', 'created_at']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 10000 &&
             data.price is number &&
             data.stock is number &&
             data.images is list && data.images.size() <= 10 &&
             data.created_at is string && data.created_at.size() <= 100;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
