{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the shop",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "specs": { "type": "object" },
        "created_at": { "type": "string" }
      },
      "required": ["title", "description", "price", "stock", "images", "created_at"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available in the store"
    }
  }
}
